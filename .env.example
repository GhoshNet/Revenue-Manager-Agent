# Copy to .env and fill in. .env is git-ignored — never commit real secrets.

# Local docker Postgres (Quick start in README)
DATABASE_URL=postgresql://hackathon:hackathon@localhost:5432/hotel_hackathon

# Data site to scrape
DATA_SITE_URL=https://otel-hackathon-data-site.vercel.app

# LLM (Phase 3+). The model is pluggable — see agent/models.py.
# Pick the default model the agent/UI starts with (a registry id):
#   claude-sonnet-4-6 | claude-haiku-4-5 | groq-llama-3.3-70b |
#   groq-gpt-oss-20b  | ollama-qwen2.5   | ollama-llama3.1
AGENT_MODEL_ID=claude-sonnet-4-6

# Anthropic (paid). Needed for the claude-* models.
ANTHROPIC_API_KEY=

# Groq (free tier, open-weight Llama / GPT-OSS). Needed for groq-* models.
# Get a free key at https://console.groq.com
GROQ_API_KEY=

# Ollama (fully local, free, no key) — needs the Ollama app + `ollama pull qwen2.5`.
# OLLAMA_BASE_URL=http://localhost:11434

# Agent UI basic auth (Phase 4 deploy)
APP_USERNAME=
APP_PASSWORD=
